# MongoDB connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net

# Clerk authentication keys (from clerk.com dashboard)
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Inngest event keys (from inngest.com dashboard)
INNGEST_EVENT_KEY=...
INNGEST_SIGNING_KEY=...

# Comma-separated Clerk user IDs that have admin access
ADMIN_USER_IDS=user_abc123,user_def456

# TMDB API key (from themoviedb.org)
TMDB_API_KEY=...

# Server port (optional, defaults to 3000)
PORT=3000

# Node environment
NODE_ENV=development
